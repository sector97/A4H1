    print("FINAL REVALIDATION SUMMARY")
    print("=" * 70)
    
    for tracker, count in CHANGE_SUMMARY.items():
        if count > 0:
            print(f"🔄 {tracker.ljust(12)} Tracker : {count} changes made")
        else:
            print(f"✅ {tracker.ljust(12)} Tracker : 0 changes made")
            
    print("=" * 70)

    # Only create the extra log file if there's actually something to log
    if sum(CHANGE_SUMMARY.values()) > 0:
        print("\nGENERATING DETAILED CHANGE LOG EXCEL...")
        try:
            pd.DataFrame(CHANGE_LOGS).to_excel("Revalidation_Change_Log.xlsx", index=False)
            print(f"✅ Change log saved: {os.path.abspath('Revalidation_Change_Log.xlsx')}")
        except PermissionError:
            print("❌ PERMISSION ERROR: Could not save Change Log (Revalidation_Change_Log.xlsx). Please make sure the file is closed.")
    else:
        print("\nℹ️ No detailed change log Excel was generated because no statuses required updating.")


