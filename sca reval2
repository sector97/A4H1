        "\nEnter Application Code (Press Enter to skip):\n\n> "
    ).strip()

    session = login()
    
    # Pass service_name as output_name so it gets funneled into the exact same logic
    download_xray_report(
        session=session,
        jar_url=jar_url,
        output_name=service_name, 
        app_code=app_code if app_code else None,
    )


