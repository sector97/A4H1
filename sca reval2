        print("\n" + "=" * 70)
        print("GENERATING REVALIDATION CHANGE LOG...")
        print("=" * 70)
        log_df = pd.DataFrame(CHANGE_LOGS)
        log_filename = "Revalidation_Change_Log.xlsx"
        
        try:
            log_df.to_excel(log_filename, index=False)
            print(f"✅ Change log saved successfully: {os.path.abspath(log_filename)}")
        except PermissionError:
            print(f"❌ PERMISSION ERROR: Could not save '{log_filename}'. Please ensure the file is closed.")
    else:
        print("\nℹ️ No status changes were made to the Master trackers during this run.")


