    print("FINAL REVALIDATION SUMMARY")
    print("=" * 70)
    for tracker, count in CHANGE_SUMMARY.items():
        if count > 0: print(f"🔄 {tracker.ljust(12)} Tracker : {count} changes made")
        else: print(f"✅ {tracker.ljust(12)} Tracker : 0 changes made")
    print("=" * 70)

    if sum(CHANGE_SUMMARY.values()) > 0 and CHANGE_LOGS:
        print("\nGENERATING DETAILED CHANGE LOG EXCELS...")
        log_df = pd.DataFrame(CHANGE_LOGS)
        for app_code, group in log_df.groupby("Application Code"):
            safe_app_code = clean_filename(app_code) if app_code.strip() else "Uncategorized"
            os.makedirs(safe_app_code, exist_ok=True)
            log_path = os.path.join(safe_app_code, "Revalidation_Change_Log.xlsx")
            try:
                group.to_excel(log_path, index=False)
                print(f"✅ Change log saved: {os.path.abspath(log_path)}")
            except PermissionError: print(f"❌ PERMISSION ERROR: Could not save {log_path}.")
    else: print("\nℹ️ No detailed change log Excels were generated because no statuses required updating.")


