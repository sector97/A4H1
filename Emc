import win32com.client
import pandas as pd
import os
import csv
import re
from datetime import datetime

OUTPUT_ROOT = r"D:\ArchiveConversationExport"

os.makedirs(OUTPUT_ROOT, exist_ok=True)

LOG_FILE = os.path.join(
    OUTPUT_ROOT,
    "processed_conversations.csv"
)

EMAIL_TO_SEARCH = input(
    "Enter email address: "
).strip().lower()

def clean_filename(name):
    return re.sub(
        r'[<>:"/\\|?*]',
        "_",
        str(name)
    )[:150]

processed_conversations = set()

if os.path.exists(LOG_FILE):

    with open(
        LOG_FILE,
        "r",
        encoding="utf-8"
    ) as f:

        reader = csv.reader(f)

        for row in reader:

            if row:
                processed_conversations.add(
                    row[0]
                )

outlook = win32com.client.Dispatch(
    "Outlook.Application"
)

namespace = outlook.GetNamespace(
    "MAPI"
)

archive_store = None

for store in namespace.Folders:

    if "Online Archive" in store.Name:

        archive_store = store
        break

if archive_store is None:

    raise Exception(
        "Online Archive mailbox not found"
    )

print(
    f"Archive Found: "
    f"{archive_store.Name}"
)

matching_conversation_ids = set()

all_conversation_emails = {}

email_rows = []
attachment_rows = []

def get_folder_path(folder):

    parts = []

    current = folder

    while current:

        parts.append(current.Name)

        try:
            current = current.Parent
        except:
            break

    return "\\".join(
        reversed(parts)
    )

def email_matches(mail):

    try:

        sender = str(
            getattr(
                mail,
                "SenderEmailAddress",
                ""
            )
        ).lower()

        to_field = str(
            getattr(
                mail,
                "To",
                ""
            )
        ).lower()

        cc_field = str(
            getattr(
                mail,
                "CC",
                ""
            )
        ).lower()

        combined = (
            sender +
            ";" +
            to_field +
            ";" +
            cc_field
        )

        return (
            EMAIL_TO_SEARCH
            in combined
        )

    except:
        return False

print(
    "\nPhase 1 - Finding matching conversations..."
)

def discover_conversations(folder):

    try:

        items = folder.Items

        for item in items:

            try:

                if item.Class != 43:
                    continue

                if email_matches(item):

                    conv_id = str(
                        item.ConversationID
                    )

                    matching_conversation_ids.add(
                        conv_id
                    )

            except:
                pass

    except:
        pass

    for sub in folder.Folders:
        discover_conversations(sub)

discover_conversations(
    archive_store
)

print(
    f"Matching Conversations: "
    f"{len(matching_conversation_ids):,}"
)

print(
    "\nPhase 2 - Collecting conversation emails..."
)

def collect_conversations(folder):

    try:

        items = folder.Items

        for item in items:

            try:

                if item.Class != 43:
                    continue

                conv_id = str(
                    item.ConversationID
                )

                if (
                    conv_id
                    not in matching_conversation_ids
                ):
                    continue

                if (
                    conv_id
                    not in all_conversation_emails
                ):
                    all_conversation_emails[
                        conv_id
                    ] = []

                all_conversation_emails[
                    conv_id
                ].append(
                    (
                        item,
                        get_folder_path(folder)
                    )
                )

            except:
                pass

    except:
        pass

    for sub in folder.Folders:
        collect_conversations(sub)

collect_conversations(
    archive_store
)

print(
    f"Conversation Groups: "
    f"{len(all_conversation_emails):,}"
)

conversation_counter = 0

for conv_id, mails in all_conversation_emails.items():

    if conv_id in processed_conversations:
        continue

    mails.sort(
        key=lambda x:
        x[0].ReceivedTime
    )

    subject = clean_filename(
        mails[0][0].Subject
    )

    attachment_folder = os.path.join(
        OUTPUT_ROOT,
        "Attachments",
        subject
    )

    os.makedirs(
        attachment_folder,
        exist_ok=True
    )

    for mail, folder_path in mails:

        try:

            attachment_count = 0

            for i in range(
                1,
                mail.Attachments.Count + 1
            ):

                att = mail.Attachments.Item(i)

                save_path = os.path.join(
                    attachment_folder,
                    clean_filename(
                        att.FileName
                    )
                )

                if not os.path.exists(
                    save_path
                ):

                    att.SaveAsFile(
                        save_path
                    )

                attachment_rows.append(
                    [
                        conv_id,
                        subject,
                        att.FileName,
                        save_path
                    ]
                )

                attachment_count += 1

            email_rows.append(
                [
                    conv_id,
                    mail.Subject,
                    mail.ReceivedTime,
                    getattr(
                        mail,
                        "SenderEmailAddress",
                        ""
                    ),
                    mail.To,
                    mail.CC,
                    folder_path,
                    attachment_count
                ]
            )

        except Exception as ex:

            print(
                f"Mail Error: {ex}"
            )

    with open(
        LOG_FILE,
        "a",
        newline="",
        encoding="utf-8"
    ) as f:

        csv.writer(f).writerow(
            [conv_id]
        )

    conversation_counter += 1

    if conversation_counter % 50 == 0:

        print(
            f"Processed "
            f"{conversation_counter:,} "
            f"conversations"
        )

excel_file = os.path.join(
    OUTPUT_ROOT,
    "ConversationExport.xlsx"
)

with pd.ExcelWriter(
    excel_file,
    engine="openpyxl"
) as writer:

    pd.DataFrame(
        email_rows,
        columns=[
            "ConversationID",
            "Subject",
            "Date",
            "Sender",
            "To",
            "CC",
            "FolderPath",
            "AttachmentCount"
        ]
    ).to_excel(
        writer,
        sheet_name="Emails",
        index=False
    )

    pd.DataFrame(
        attachment_rows,
        columns=[
            "ConversationID",
            "Subject",
            "Attachment",
            "SavedPath"
        ]
    ).to_excel(
        writer,
        sheet_name="Attachments",
        index=False
    )

print("\nCompleted")
print(f"Excel: {excel_file}")
print(f"Output Folder: {OUTPUT_ROOT}")
